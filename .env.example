# Database
DB_USER=secure_user
DB_PASSWORD=a_very_strong_db_password_here
DB_NAME=makeit
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}

# Redis
REDIS_URL=redis://localhost:6379/0

# API Keys (Required for production)
SENTINELHUB_CLIENT_ID=your_client_id
SENTINELHUB_CLIENT_SECRET=your_client_secret
MAPBOX_ACCESS_TOKEN=your_mapbox_token

# App Config & Security
ENVIRONMENT=production
DEBUG=False
ALLOWED_ORIGINS=http://localhost:3000,https://my-sentinel.app

PASSWORD_PEPPER=this_should_be_a_high_entropy_secret_string

# RS256 Tokens
# Generate with: openssl genrsa -out private.pem 4096 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----"

JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
...
-----END PUBLIC KEY-----"

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting & Safety
RATE_LIMIT_GLOBAL=120/minute
RATE_LIMIT_DETECT=10/minute
RATE_LIMIT_AUTH=5/minute
MAX_AOI_AREA_KM2=10000
